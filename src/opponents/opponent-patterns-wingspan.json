{
  "gameId": "wingspan",
  "gameName": "Wingspan",
  "version": "1.0.0",
  
  "detectors": {
    "food_caching_rate": {
      "type": "frequency",
      "sample_size": 10,
      "match": { "action": "cache_food" },
      "description": "Hur ofta spelaren cachar mat på fåglar"
    },
    
    "egg_laying_focus": {
      "type": "frequency",
      "sample_size": 10,
      "match": { "action": "lay_eggs" },
      "description": "Frekvens av äggläggning som primär action"
    },
    
    "card_draw_preference": {
      "type": "frequency",
      "sample_size": 10,
      "match": { "action": "draw_cards" },
      "description": "Hur ofta spelaren drar kort istället för annat"
    },
    
    "tucking_frequency": {
      "type": "frequency",
      "sample_size": 10,
      "match": { "action": "tuck_card" },
      "description": "Hur ofta spelaren tuckar kort under fåglar"
    },
    
    "raven_crow_usage": {
      "type": "frequency",
      "sample_size": 15,
      "match": { "bird_type": "raven_crow" },
      "description": "Användning av ravens och crows (food stealing)"
    },
    
    "predator_usage": {
      "type": "frequency",
      "sample_size": 15,
      "match": { "power_type": "predator" },
      "description": "Spelar fåglar som äter ägg från andra"
    },
    
    "habitat_diversity": {
      "type": "average",
      "field": "habitats_used",
      "description": "Genomsnittligt antal olika habitat i bruk"
    },
    
    "bonus_card_completion": {
      "type": "ratio",
      "numerator": { "action": "complete_bonus" },
      "denominator": { "action": "any" },
      "description": "Andel spelad tid som fokuserar på bonuskort"
    },
    
    "round4_burst": {
      "type": "trend",
      "metric": "birds_played",
      "description": "Spelar spelaren fler fåglar i runda 4?"
    },
    
    "engine_building_rate": {
      "type": "average",
      "field": "birds_with_when_activated",
      "description": "Genomsnittligt antal when-activated powers"
    }
  },
  
  "strategies": {
    "egg_engine": {
      "name": "Ägg-motor (Egg Engine)",
      "description": "Bygger motor för massiv äggproduktion",
      "indicators": [
        {
          "pattern": "egg_laying_focus",
          "weight": 30,
          "threshold": { "min": 0.4 }
        },
        {
          "pattern": "food_caching_rate",
          "weight": 20,
          "threshold": { "min": 0.3 }
        },
        {
          "pattern": "engine_building_rate",
          "weight": 25,
          "threshold": { "min": 3.5 }
        },
        {
          "pattern": "habitat_diversity",
          "weight": 25,
          "threshold": { "max": 2.2 }
        }
      ],
      "predictedBehaviors": [
        {
          "action": "play_platform_nest_birds",
          "probability": 0.85,
          "reasoning": "Platform nests ger mest ägg"
        },
        {
          "action": "activate_grassland_repeatedly",
          "probability": 0.90,
          "reasoning": "Grassland är ägg-habitat"
        },
        {
          "action": "ignore_predators",
          "probability": 0.75,
          "reasoning": "Vill inte förlora ägg genom predators"
        }
