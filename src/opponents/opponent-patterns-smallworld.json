        "priority": 85
      }
    },
    "race_cycling": {
      "name": "Decline Cycler",
      "description": "Maximizing value through frequent race changes",
      "detectors": ["decline_cycler"],
      "threat_level": "HIGH",
      "counter_strategy": {
        "action": "attack_decline_tokens",
        "message": "Opponent cycling races - attack their decline tokens for easy points!",
        "priority": 80
      }
    },
    "defensive": {
      "name": "Turtle Defender",
      "description": "Holding strong positions with stacked tokens",
      "detectors": ["turtle_defender"],
      "threat_level": "MEDIUM",
      "counter_strategy": {
        "action": "expand_elsewhere",
        "message": "Opponent turtling - expand in areas they're not defending.",
        "priority": 70
