  "threat_assessment": {
    "CRITICAL": {
      "indicators": ["10_plus_regions", "strong_race_power_combo", "many_bonus_regions"],
      "response": "Coordinate attacks with other players"
    },
    "HIGH": {
      "indicators": ["7_plus_regions", "aggressive_expansion", "bonus_exploitation"],
      "response": "Target their weak spots actively"
    },
    "MEDIUM": {
      "indicators": ["moderate_regions", "steady_scoring"],
      "response": "Monitor and compete for resources"
