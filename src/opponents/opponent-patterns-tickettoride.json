      "strategy": "aggressive_blocker",
      "conditions": {
        "blocking_behavior": { "min": 0.5 }
      },
      "level": "high",
      "reasoning": "Kan förstöra din strategi"
    },
    {
      "strategy": "ticket_completionist",
      "level": "medium",
      "reasoning": "Konsekvent men förutsägbar"
    },
    {
      "strategy": "balanced_optimizer",
      "level": "low",
      "reasoning": "Säker spelstil, lägre threat"
    }
  ],

  "inferenceRules": {
    "color_targeting": {
      "description": "Vilka rutter siktar de på baserat på färger de samlar?",
      "patterns": [
        {
